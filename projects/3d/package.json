{
    "name": "@nil-/3d",
    "version": "0.4.0",
    "author": {
        "email": "njaldea@gmail.com",
        "name": "Neil Aldea"
    },
    "license": "ISC",
    "scripts": {
        "build": "vite build",
        "check": "svelte-check --tsconfig ./tsconfig.json",
        "dev": "vite dev",
        "gen:package": "svelte-package -o package",
        "gen:meta": "npx @nil-/postpackage ./package",
        "package": "pnpm run gen:package && pnpm run gen:meta",
        "sync": "svelte-kit sync",
        "lint": "eslint . --ignore-path ../../.eslintignore"
    },
    "devDependencies": {
        "@nil-/doc": "workspace:^",
        "@nil-/doc-kit": "workspace:^",
        "@nil-/postpackage": "workspace:^",
        "@sveltejs/adapter-vercel": "^5.10.3",
        "@sveltejs/kit": "^2.61.1",
        "@sveltejs/package": "^2.5.7",
        "@sveltejs/vite-plugin-svelte": "5.0.1",
        "@types/earcut": "^2.1.4",
        "mdsvex": "^0.12.7",
        "svelte-check": "^3.8.6",
        "tslib": "^2.8.1",
        "typescript": "^5.9.3",
        "vite": "^6.4.2"
    },
    "peerDependencies": {
        "@babylonjs/core": "^5.57.1",
        "@babylonjs/gui": "^5.57.1",
        "@babylonjs/inspector": "^5.57.1",
        "@babylonjs/materials": "^5.57.1",
        "earcut": "^2.2.4",
        "svelte": "^5.7.1"
    },
    "publishConfig": {
        "directory": "package",
        "linkDirectory": true
    },
    "keywords": [
        "svelte",
        "babylonjs",
        "3D"
    ],
    "type": "module",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "default": "./index.js",
            "svelte": "./index.js",
            "types": "./index.d.ts"
        }
    }
}
